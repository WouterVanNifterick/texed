{
  "name": "texed-ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm build:library && vite",
    "build": "pnpm build:library && pnpm typecheck && vite build",
    "build:library": "tsx scripts/build-patch-library.mts",
    "cli": "pnpm --filter @texed/cli start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint",
    "prepare": "cd .. && husky texed-ts/.husky",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "pnpm -r typecheck && tsc -b"
  },
  "lint-staged": {
    "*.{ts,tsx,mts}": [
      "oxlint",
      "prettier --write"
    ],
    "*.{css,json,md,html}": "prettier --write"
  },
  "dependencies": {
    "@texed/dx7-engine": "workspace:*",
    "@texed/dx7-format": "workspace:*",
    "@texed/synth-protocol": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "~7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
