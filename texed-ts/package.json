{
  "name": "texed-ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm build:library && vite",
    "build": "pnpm build:library && pnpm typecheck && vite build",
    "build:library": "tsx scripts/build-patch-library.mts",
    "cli": "pnpm --filter @texed/cli start",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck && tsc -b"
  },
  "dependencies": {
    "@texed/dx7-engine": "workspace:*",
    "@texed/dx7-format": "workspace:*",
    "@texed/synth-protocol": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
